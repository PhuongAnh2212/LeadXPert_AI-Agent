    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@openrouter/agent": "^0.7.2",
    "@slack/bolt": "^3.17.0",
    "dotenv": "^16.0.0",
    "node-fetch": "^3.3.2",
    "zod": "^4.4.3"
  }
}
