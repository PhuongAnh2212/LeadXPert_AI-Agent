{
  "name": "doc-agent-system",
  "version": "1.0.0",
  "description": "Two-agent documentation system for PRD generation, feedback learning, knowledge ingestion, and Q&A.",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "demo": "node index.js demo ../samplePRD/sample-prd-scheduled-compliance-reports.md",
